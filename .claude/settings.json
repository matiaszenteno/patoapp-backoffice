{
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-env-edit.sh" }]
      },
      {
        "matcher": "mcp__supabase__apply_migration|mcp__supabase__deploy_edge_function|mcp__supabase__execute_sql|mcp__supabase__create_branch|mcp__supabase__delete_branch|mcp__supabase__merge_branch|mcp__supabase__rebase_branch|mcp__supabase__reset_branch",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-supabase-direct.sh" }]
      }
    ]
  }
}
